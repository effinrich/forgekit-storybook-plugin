{
  "name": "@effinrich/forgekit-nx-storybook",
  "version": "2.3.0",
  "description": "Auto-generate Storybook stories, interaction tests, Playwright component tests, and accessibility audits from React component analysis",
  "author": "Rich Tillman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/effinrich/forgekit"
  },
  "keywords": [
    "storybook",
    "react",
    "testing",
    "code-generation",
    "interaction-tests",
    "playwright",
    "accessibility",
    "a11y",
    "story-generation"
  ],
  "bin": {
    "forgekit": "./bin/forgekit.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=18.17.1"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "typecheck": "npx tsc --noEmit",
    "release": "commit-and-tag-version",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major",
    "postrelease": "git push --follow-tags origin main && npm publish --access public"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "fast-glob": "^3.3.3",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/yargs": "^17.0.33",
    "commit-and-tag-version": "^12.7.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "storybook": ">=8.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "storybook": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  }
}
